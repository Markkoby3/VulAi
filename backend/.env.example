# VulAI Backend Configuration

# Server
BACKEND_HOST=localhost
BACKEND_PORT=8000
DEBUG=false

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-opus-4-20250514

# Analysis
ANALYSIS_TIMEOUT=30
ENABLE_CACHING=true

# Logging
LOG_LEVEL=INFO
ENABLE_LOGGING=true
